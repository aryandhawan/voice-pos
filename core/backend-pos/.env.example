# Module 2: AI Voice Ordering Copilot - Environment Configuration

# Server Configuration
PORT=8000
HOST=0.0.0.0
ENV=development

# Module 1 Integration (Critical)
MODULE1_WEBHOOK_SECRET=hackathon_2026_secure_sync_key
ALLOWED_MODULE1_IPS=192.168.1.45,192.168.1.46

# Vector Database
CHROMA_DB_PATH=./chroma_db
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Speech-to-Text
WHISPER_MODEL=base
WHISPER_DEVICE=cpu

# Audio Processing
MAX_AUDIO_SIZE_MB=25
ENABLE_NOISE_REDUCTION=false

# Restaurant Configuration
RESTAURANT_ID=REST001
TAX_PERCENTAGE=5.0

# Logging
LOG_LEVEL=INFO
